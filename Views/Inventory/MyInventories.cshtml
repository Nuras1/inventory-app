@using project_itransition.Resources
@model IEnumerable<project_itransition.Models.Entities.Inventory>

<h1 class="fw-bold mb-4">
    @Resource.MyInventories
</h1>

<a asp-action="Create"
   class="btn btn-success mb-4 px-4">

    @Resource.CreateInventory

</a>
<div class="bulk-actions-toolbar mb-4 d-none"
     id="bulkToolbar">

    <div class="d-flex flex-wrap gap-2 align-items-center">

        <span class="toolbar-title">
            @Resource.SelectedInventory
        </span>

        <a id="openInventoryBtn"
           class="btn btn-outline-primary rounded-pill px-4">

            @Resource.Open

        </a>

        <a id="editInventoryBtn"
           class="btn btn-primary rounded-pill px-4">

            @Resource.Edit

        </a>

        <a id="deleteInventoryBtn"
           class="btn btn-danger rounded-pill px-4">

            @Resource.Delete

        </a>

    </div>

</div>
<div class="card shadow-sm border rounded-4 bg-body-tertiary">

    <div class="card-body">

        <table class="table table-hover align-middle mb-0">

            <thead>

                <tr>
                    <th style="width: 50px;"></th>

                    <th>@Resource.Title</th>

                    <th>@Resource.Category</th>

                    <th>@Resource.Public</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr class="inventory-row" data-id="@item.Id">

                        <td>

                            <input type="radio" name="selectedInventory" value="@item.Id"
                                   class="form-check-input inventory-selector">

                        </td>

                        <td class="fw-semibold">
                            @item.Title
                        </td>

                        <td>
                            @item.Category
                        </td>

                        <td>

                            @if (item.IsPublic)
                            {
                                <span class="badge bg-success">
                                    @Resource.Public
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    @Resource.Private
                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
