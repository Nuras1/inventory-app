@using project_itransition.Resources
@model project_itransition.ViewModels.Inventory.CreateInventoryViewModel

@{
    ViewData["Title"] = Resource.CreateInventory;
}

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <h1 class="fw-bold mb-4">
                @Resource.CreateInventory
            </h1>

            <div class="card border-0 rounded-4 bg-body-tertiary">

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger">
                        </div>

                        <div class="mb-4">

                            <h5 class="fw-semibold mb-3">
                                Basic Information
                            </h5>

                            <div class="mb-3">

                                <label asp-for="Title"
                                       class="form-label fw-semibold">
                                </label>

                                <input asp-for="Title"
                                       class="form-control rounded-3" />

                                <span asp-validation-for="Title"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="mb-3">

                                <label asp-for="Description"
                                       class="form-label fw-semibold">
                                </label>

                                <textarea asp-for="Description"
                                          class="form-control rounded-3"
                                          rows="4">
                                </textarea>

                                <span asp-validation-for="Description"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="mb-0">

                                <label asp-for="Category"
                                       class="form-label fw-semibold">
                                </label>

                                <input asp-for="Category"
                                       class="form-control rounded-3"
                                       placeholder="Books, Electronics, Games..." />

                                <span asp-validation-for="Category"
                                      class="text-danger">
                                </span>

                            </div>

                        </div>

                        <div class="mb-4">

                            <h5 class="fw-semibold mb-3">
                                Customization
                            </h5>

                            <div class="mb-3">

                                <label class="form-label fw-semibold">
                                    Custom ID Format
                                </label>

                                <input asp-for="CustomIdFormat"
                                       class="form-control rounded-3"
                                       placeholder="BOOK-{SEQ}" />

                                <small class="text-secondary">

                                    Examples:
                                    BOOK-{SEQ},
                                    INV-{YEAR}-{SEQ},
                                    LAP-{RAND6}

                                </small>

                                <div class="small text-secondary mt-2">
                                    Example: BOOK-0001
                                </div>

                            </div>

                            <div class="mb-0">

                                <label asp-for="Prefix"
                                       class="form-label fw-semibold">
                                </label>

                                <input asp-for="Prefix"
                                       class="form-control rounded-3"
                                       placeholder="INV" />

                                <span asp-validation-for="Prefix"
                                      class="text-danger">
                                </span>

                            </div>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Tags"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Tags"
                                   class="form-control rounded-3"
                                   placeholder="books, fantasy, manga" />

                            <small class="text-secondary">
                                Separate tags with commas
                            </small>

                        </div>

                        <div class="mb-4">

                            <div class="form-check form-switch">

                                <input asp-for="IsPublic"
                                       class="form-check-input" />

                                <label class="form-check-label fw-semibold"
                                       asp-for="IsPublic">

                                    Public Inventory

                                </label>

                            </div>

                            <small class="text-secondary">
                                Public inventories can be viewed by other users
                            </small>

                        </div>

                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-primary px-3 rounded-3">

                                @Resource.Create

                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary px-3 rounded-3">

                                @Resource.Cancel

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}