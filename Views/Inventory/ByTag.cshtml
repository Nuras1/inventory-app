@using project_itransition.Resources
@model IEnumerable<project_itransition.Models.Entities.Inventory>

<div class="d-flex align-items-center gap-3 mb-2">

    <h1 class="fw-bold mb-0">
        @Resource.Tags
    </h1>

    <span class="badge text-bg-secondary fs-6 px-3 py-2">
        #@ViewBag.Tag
    </span>

</div>

<p class="text-body-secondary mb-4">
    @Model.Count() @Resource.InventoriesFoundWithThisTag.
</p>

<a asp-action="Index"
   class="btn btn-outline-secondary btn-sm mb-4">

    <i class="bi bi-arrow-left"></i>
    @Resource.BackToInventories

</a>

<div class="card shadow-sm border rounded-4 bg-body-tertiary">

    <div class="card-body">

        <table class="table table-hover align-middle mb-0">

            <thead>

                <tr>
                    <th>@Resource.Title</th>
                    <th>@Resource.Category</th>
                    <th>@Resource.Owner</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>

                            <a asp-action="Details" asp-route-id="@item.Id">

                                @item.Title

                            </a>

                        </td>

                        <td>@item.Category</td>

                        <td>@item.Owner.FullName</td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>