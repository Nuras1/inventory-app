@using project_itransition.Resources
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - project_itransition</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/project_itransition.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/user-management.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inventory-details.css" asp-append-version="true" />

</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar bg-body-tertiary shadow-sm mb-4">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav me-auto gap-2">

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link "
                                   asp-controller="Admin"
                                   asp-action="Index">
                                    @Resource.UserManagement
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Inventory"
                               asp-action="Index">
                                @Resource.Inventories
                            </a>
                        </li>

                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Inventory" asp-action="MyInventories">@Resource.MyInventories</a>
                            </li>
                        }
                    </ul>
                    @if ( ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory")
                    {
                        <form class="d-flex me-3"
                              asp-controller="Inventory"
                              asp-action="Search"
                              method="get">

                            <div class="position-relative">

                                <input class="form-control form-control-sm rounded-pill pe-5"
                                       type="search"
                                       id="searchInput"
                                       name="query"
                                       placeholder="Search inventories or tags"
                                       value="@Context.Request.Query["query"]"
                                       style="width:240px" />

                            </div>

                        </form>
                    }
                    <div class="p-2 border rounded">

                        <div class="form-check form-switch">

                            <input class="form-check-input"
                                   type="checkbox"
                                   id="btnSwitch">

                            <label class="form-check-label"
                                   for="btnSwitch">
                                @Resource.DarkMode
                            </label>

                        </div>

                    </div>
                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                    <div class="nav-item dropdown">
                        <button class="nav-link btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            @if (Thread.CurrentThread.CurrentCulture.ToString() == "en")
                            {
                                <span>English</span>
                            }
                            else
                            {
                                <span>Русский</span>
                            }

                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="ChangeLanguage" asp-route-lang="en">English</a></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="ChangeLanguage" asp-route-lang="ru">Русский</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main class="flex-grow-1 px-5 pb-3">
            @RenderBody()
        </main>
        @if (TempData["Error"] != null)
        {
            <div id="autoCloseAlert"
                 class="alert alert-danger alert-dismissible fade show mt-3">

                @TempData["Error"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>
        }

    <footer class="border-top text-body-secondary bg-body-tertiary py-3">
        <div class="container">
            &copy; 2026 - Inventory App 
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
