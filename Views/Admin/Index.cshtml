@using project_itransition.Resources
@model IEnumerable<project_itransition.ViewModels.Admin.UserManagementViewModel>

<h1 class="fw-bold mb-4">
    @Resource.UserManagement
</h1>

<div class="user-management-wrapper">

    <div class="bulk-actions-toolbar mb-4 d-none"
         id="bulkToolbar">

        <div class="d-flex flex-wrap gap-2 align-items-center">

            <span class="toolbar-title">
                @Resource.SelectedUser
            </span>

            <form asp-action="Block" method="post">
                <input type="hidden"
                       name="Id"
                       id="blockUserId">

                <button type="submit"
                        class="btn btn-danger rounded-pill px-4">

                    @Resource.Block

                </button>
            </form>

            <form asp-action="UnBlock" method="post">
                <input type="hidden" name="Id" id="unblockUserId">

                <button type="submit"
                        class="btn btn-success rounded-pill px-4">

                    @Resource.Unblock

                </button>
            </form>

            <form asp-action="MakeAdmin" method="post">
                <input type="hidden" name="Id" id="makeAdminUserId">

                <button type="submit"
                        class="btn btn-primary rounded-pill px-4">

                    @Resource.MakeAdmin

                </button>
            </form>

            <form asp-action="RemoveAdmin" method="post">
                <input type="hidden" name="Id" id="removeAdminUserId">

                <button type="submit"
                        class="btn btn-secondary rounded-pill px-4">

                    @Resource.RemoveAdmin

                </button>
            </form>

            <form asp-action="Delete" method="post">
                <input type="hidden" name="Id" id="deleteUserId">

                <button type="submit"
                        class="btn btn-danger rounded-pill px-4">

                    @Resource.Delete

                </button>
            </form>

        </div>

    </div>

    <table class="table align-middle mb-0 user-management-table">

        <thead>

            <tr>

                <th style="width: 50px;"></th>

                <th>@Resource.User</th>

                <th>@Resource.Status</th>

                <th>@Resource.Role</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var user in Model)
            {
                <tr class="user-row" data-user-id="@user.Id">

                    <td>

                        <input type="radio" name="selectedUser" value="@user.Id"
                               class="form-check-input user-selector">

                    </td>

                    <td>

                        <div class="user-cell">

                            <div class="user-avatar">

                                @(string.IsNullOrEmpty(user.FullName)
                                    ? "U"
                                    : user.FullName.Substring(0, 1).ToUpper())

                            </div>

                            <div>

                                <div class="user-name">
                                    @user.FullName
                                </div>

                                <div class="user-email">
                                    @user.Email
                                </div>

                            </div>

                        </div>

                    </td>

                    <td>

                        @if (user.IsBlocked)
                        {
                            <span class="status-badge status-blocked">
                                @Resource.Blocked
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-active">
                                @Resource.Active
                            </span>
                        }

                    </td>

                    <td>

                        @if (user.IsAdmin)
                        {
                            <span class="role-badge role-admin">
                                @Resource.Admin
                            </span>
                        }
                        else
                        {
                            <span class="role-badge role-user">
                                @Resource.User
                            </span>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>